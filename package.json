{
  "name": "project-box",
  "version": "0.1.16",
  "description": "项目盒子 - 本地多项目文件管理与编辑工具",
  "author": "Project Box",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "web:dev": "vite --host 127.0.0.1",
